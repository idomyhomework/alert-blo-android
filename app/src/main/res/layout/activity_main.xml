<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="AlertBLO Admin"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crear alerta"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <EditText
        android:id="@+id/editTextAlerta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Texto de la alerta"
        android:layout_marginTop="8dp" />

    <Switch
        android:id="@+id/switchSilencio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modo silencio"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnCrearAlerta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar alerta"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alertas recibidas"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

    <ListView
        android:id="@+id/listaAlertas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

</LinearLayout>